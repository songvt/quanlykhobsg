{
    "crons": [
        {
            "path": "/api/cron-sync",
            "schedule": "0 0 * * *"
        }
    ],
    "headers": [
        {
            "source": "/(.*).html",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
        },
        {
            "source": "/",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
        },
        {
            "source": "/index.html",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
                { "key": "Pragma", "value": "no-cache" },
                { "key": "Expires", "value": "0" }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/settlement_history",
            "destination": "/api/settlements?type=history"
        },
        {
            "source": "/api/settlement_inventory",
            "destination": "/api/settlements?type=inventory"
        },
        {
            "source": "/api/settlement_outbound",
            "destination": "/api/settlements?type=outbound"
        },
        {
            "source": "/api/stats",
            "destination": "/api/settlements?type=stats"
        },
        {
            "source": "/api/asset_logs",
            "destination": "/api/assets?type=logs"
        },
        {
            "source": "/api/asset_handovers",
            "destination": "/api/assets?type=handovers"
        },
        {
            "source": "/api/drive_upload",
            "destination": "/api/system_utils?type=drive_upload"
        },
        {
            "source": "/api/telegram",
            "destination": "/api/system_utils?type=telegram"
        },
        {
            "source": "/api/qr_logs",
            "destination": "/api/audits?type=qr"
        },
        {
            "source": "/api/hr_profiles",
            "destination": "/api/employees?type=hr_profiles"
        },
        {
            "source": "/api/kpi_infractions",
            "destination": "/api/employees?type=kpi_infractions"
        },
        {
            "source": "/api/district_storekeepers",
            "destination": "/api/employees?type=district_storekeepers"
        },
        {
            "source": "/api/employee_returns",
            "destination": "/api/employees?type=employee_returns"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}